<Window
    x:Class="桌面萌宠.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="桌面萌宠"
    Width="120"
    Height="120"
    AllowsTransparency="True"
    Background="Transparent"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    MouseRightButtonDown="Window_MouseRightButtonDown"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">

    <Grid Background="Transparent">
        <!--  使用标准 Image 控件  -->
        <Image
            Name="PetImage"
            Margin="0"
            Stretch="Uniform" />

        <!--  右键菜单  -->
        <Grid.ContextMenu>
            <ContextMenu>

                <!--  大小调整 - 二级菜单  -->
                <MenuItem Header="📐 大小">
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="25%"
                        Tag="0.25" />
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="50%"
                        Tag="0.5" />
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="75%"
                        Tag="0.75" />
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="100%"
                        Tag="1.0" />
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="125%"
                        Tag="1.25" />
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="150%"
                        Tag="1.5" />
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="175%"
                        Tag="1.75" />
                    <MenuItem
                        Click="SizePercentage_Click"
                        Header="200%"
                        Tag="2.0" />
                </MenuItem>

                <Separator />
                <MenuItem Click="ResetPosition_Click" Header="🔄 重置位置" />
                <Separator />
                <MenuItem Click="ToggleTopmost_Click" Header="📌 取消置顶" />
                <MenuItem Click="Exit_Click" Header="❌ 退出" />
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
